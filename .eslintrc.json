{
	"env": {
		"es2021": true,
		"node": true
	},
	"extends": ["standard"],
	"parser": "@typescript-eslint/parser",
	"parserOptions": {
		"ecmaVersion": "latest",
		"sourceType": "module"
	},
	"plugins": ["@typescript-eslint"],
	"rules": {
		"no-tabs": "off",
		"indent": "off",
		"no-console": "off",
		"no-unused-vars": "off",
		"space-before-function-paren": "off"
	}
}
